# ─── Core ───
DATABASE_URL=postgresql://localhost:5432/realestateos
JWT_SECRET=change-me-in-production
PORT=3001
NODE_ENV=development

# ─── Redis (BullMQ queues + workers) ───
REDIS_URL=redis://localhost:6379

# ─── Santander Banking ───
# Credentials are stored per-org in the bank_credentials table.
# CERTS_ROOT points to the directory containing org certificate folders.
# Structure: certs/{org-slug}/cert.pem + key.pem
CERTS_ROOT=../../certs

# ─── AWS (Textract OCR + SES Email) ───
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=realestateos

# ─── AWS SES (Email) ───
# AWS_SES_REGION=us-east-1
# SES_FROM_EMAIL=noreply@realestateos.com.br

# ─── WhatsApp Business Cloud API ───
# WHATSAPP_TOKEN=your-whatsapp-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_API_VERSION=v21.0

# ─── Twilio (SMS) ───
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+15551234567

# ─── Gemini AI (RAG chatbot + AI agents) ───
# GEMINI_API_KEY=your-gemini-api-key

# ─── Evolution API (WhatsApp open-source) ───
# Configured per-org via channel_configs table.
# EVOLUTION_API_URL=https://evolution.example.com
# EVOLUTION_API_KEY=your-evolution-api-key
# EVOLUTION_INSTANCE_NAME=your-instance
