# ─── Core ───
DATABASE_URL=postgresql://localhost:5432/realestateos
JWT_SECRET=change-me-in-production
PORT=3001
NODE_ENV=development

# ─── Redis (BullMQ queues + workers) ───
REDIS_URL=redis://localhost:6379

# ─── Santander Banking ───
# Credentials are stored per-org in the bank_credentials table.
# Local dev: CERTS_ROOT points to cert files on disk.
# Railway/cloud: store cert+key as base64 env vars instead.
CERTS_ROOT=../../certs
# BANK_CERT_B64=<base64-encoded cert.pem content>
# BANK_KEY_B64=<base64-encoded key.pem content>

# ─── Email SMTP ───
# Configurado POR IMOBILIÁRIA no banco (organizations.smtp_settings).
# Cada imobiliária cadastra suas credenciais SMTP no onboarding.
# Exemplo de smtp_settings JSON:
#   { "host": "smtppro.zoho.com", "port": 587, "user": "...", "pass": "...", "from": "..." }

# ─── Gemini AI (RAG chatbot + AI agents) ───
# GEMINI_API_KEY=your-gemini-api-key
