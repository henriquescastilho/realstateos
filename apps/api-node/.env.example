# ─── Core ───
DATABASE_URL=postgresql://localhost:5432/realestateos
JWT_SECRET=change-me-in-production
PORT=3001
NODE_ENV=development

# ─── Santander Banking (boleto + PIX) ───
# SANTANDER_BASE_URL=https://trust-sandbox.api.santander.com.br
# SANTANDER_CLIENT_ID=your-client-id
# SANTANDER_CLIENT_SECRET=your-client-secret
# SANTANDER_WORKSPACE_ID=your-workspace-id

# ─── AWS (Textract OCR + SES Email) ───
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=realestateos

# ─── AWS SES (Email) ───
# AWS_SES_REGION=us-east-1
# SES_FROM_EMAIL=noreply@realestateos.com.br

# ─── WhatsApp Business Cloud API ───
# WHATSAPP_TOKEN=your-whatsapp-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_API_VERSION=v21.0

# ─── Twilio (SMS) ───
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+15551234567
