# Local development only. For Railway later, copy the same variables into each service.

POSTGRES_DB=realestateos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379

# Optional object storage for MVP/local demo
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=realestateos

# Shared backend settings
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/realestateos
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
GOOGLE_ADK_MODEL=gemini-2.0-flash
WORKER_POLL_INTERVAL_SECONDS=2
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Santander / payment fallback
SANTANDER_SANDBOX_ENABLED=true
SANTANDER_BASE_URL=https://sandbox.santander.example
SANTANDER_CLIENT_ID=sandbox-client-id
SANTANDER_CLIENT_SECRET=sandbox-client-secret
PAYMENT_MOCK_FALLBACK_ENABLED=true

# Service ports
API_PORT=8000
WORKER_PORT=8081
WEB_PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
