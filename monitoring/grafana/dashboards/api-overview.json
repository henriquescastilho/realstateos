        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "p95 Latency (SLO: <200ms)",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_request_duration_seconds_bucket{job=\"realstateos-api\"}[5m]))) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
